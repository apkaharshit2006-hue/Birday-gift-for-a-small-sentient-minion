{
  "name": "desktop-pets",
  "version": "2.0.0",
  "description": "5 interactive desktop pets",
  "repository": {
    "type": "git",
    "url": "https://github.com/apkaharshit2006-hue/Birday-gift-for-a-small-sentient-minion.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "publish": "electron-builder -p always"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-updater": "^6.1.7"
  },
  "build": {
    "appId": "com.desktoppets.app",
    "productName": "Desktop Pets",
    "publish": [
      {
        "provider": "github",
        "owner": "apkaharshit2006-hue",
        "repo": "Birday-gift-for-a-small-sentient-minion"
      }
    ],
    "files": [
      "main.js",
      "app-settings.js",
      "pet-ai.js",
      "scribble-fix.js",
      "index.html",
      "chat.html",
      "overlay.html",
      "settings.html"
    ],
    "directories": { "output": "dist" }
  }
}
